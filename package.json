{
  "name": "my-gudauri",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloudflare": "npm run build && wrangler pages dev",
    "build": "vite build && npm run copy:assets",
    "copy:assets": "node scripts/copy-static-assets.mjs",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 migrations apply my-gudauri-cms --local",
    "db:migrate:remote": "wrangler d1 migrations apply my-gudauri-cms --remote",
    "db:seed:local": "wrangler d1 execute my-gudauri-cms --local --file ./db/seed.sql",
    "db:seed:remote": "wrangler d1 execute my-gudauri-cms --remote --file ./db/seed.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "sass": "^1.93.2",
    "vite": "^5.4.19",
    "wrangler": "^4.110.0"
  }
}
