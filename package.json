{
  "name": "my-gudauri",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "design:sync": "sass src/styles/tokens/index.scss styles/tokens.css --no-source-map --style=expanded && sass src/styles/SystemCompat.scss styles/system.css --no-source-map --style=expanded && sass src/components/UI/SectionHeading/SectionHeading.scss styles/section-heading.css --no-source-map --style=expanded && sass src/pages/ProfilePage/ProfileLegacy.scss styles/design-3-profile.css --no-source-map --style=expanded && node scripts/sync-legacy-assets.mjs",
    "predev": "npm run design:sync",
    "dev": "vite",
    "dev:cloudflare": "npm run build && wrangler pages dev",
    "build": "npm run design:sync && vite build && npm run copy:assets",
    "copy:assets": "node scripts/copy-static-assets.mjs",
    "preview": "vite preview",
    "architecture:report": "node scripts/generate-design-architecture-report.mjs",
    "architecture:check": "tsc -p tsconfig.architecture.json --noEmit && node scripts/generate-design-architecture-report.mjs --check",
    "prestorybook": "npm run architecture:report",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run architecture:report",
    "build-storybook": "storybook build",
    "db:migrate:local": "wrangler d1 migrations apply my-gudauri-cms --local",
    "db:migrate:remote": "wrangler d1 migrations apply my-gudauri-cms --remote",
    "db:seed:local": "wrangler d1 execute my-gudauri-cms --local --file ./db/seed.sql",
    "db:seed:remote": "wrangler d1 execute my-gudauri-cms --remote --file ./db/seed.sql"
  },
  "dependencies": {
    "@daypicker/react": "^10.0.1",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-popover": "^1.1.19",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "sass": "^1.93.2",
    "storybook": "^10.5.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "wrangler": "^4.110.0"
  }
}
